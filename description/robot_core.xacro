<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="inertial_macros.xacro"/>


    <xacro:property name="chassis_length" value="0.92"/>
    <xacro:property name="chassis_width" value="0.505"/>
    <xacro:property name="chassis_height" value="0.40"/>
    <xacro:property name="chassis_mass" value="40.0"/>
    <xacro:property name="wheel_radius" value="0.1016"/>
    <xacro:property name="wheel_thickness" value="0.0508"/>
    <xacro:property name="wheel_mass" value="0.6"/>
    <xacro:property name="wheel_offset_x" value="0.265"/>
    <xacro:property name="wheel_offset_y" value="0.1485"/>
    <xacro:property name="wheel_offset_z" value="0.01"/>
    <xacro:property name="caster_wheel_radius" value="0.1016"/>
    <xacro:property name="caster_wheel_mass" value="0.6"/>
    <xacro:property name="caster_wheel_offset_x" value="0.075"/>
    <xacro:property name="caster_wheel_offset_z" value="${wheel_offset_z - wheel_radius + caster_wheel_radius}"/>

    <!-- SOLAR PANEL PROPERTIES -->
    <xacro:property name="solar_length" value="0.7"/>
    <xacro:property name="solar_width" value="0.51"/>
    <xacro:property name="solar_thickness" value="0.02"/>
    <xacro:property name="solar_mass" value="1.0"/>
    <xacro:property name="solar_angle" value="0.145"/>

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1.0 0.094 0.094 1"/>
    </material>

    <material name="silver">
        <color rgba="0.753 0.753 0.753 1"/>
    </material>

    <!-- BASE LINK -->

    <link name="base_link">

    </link>

    <!-- BASE_FOOTPRINT LINK -->

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 ${-wheel_radius}" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>


    <!-- CHASSIS LINK -->

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="${-wheel_offset_x} 0 ${-wheel_offset_z}"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="${chassis_length/2} 0 ${chassis_height/2}"/>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="${chassis_length/2} 0 ${chassis_height/2}"/>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
            <origin xyz="${chassis_length/2} 0 ${chassis_height/2}" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Red</material>
    </gazebo>

    <!-- LEFT WHEEL LINK -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.55 ${wheel_offset_y} 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Black</material>
    </gazebo>


    <!-- RIGHT WHEEL LINK -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.55 ${-wheel_offset_y} 0" rpy="${pi/2} 0 0" />
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Black</material>
    </gazebo>


    <!-- REAR LEFT WHEEL LINK -->

    <joint name="rear_left_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_left_wheel"/>
        <origin xyz="${-2 * caster_wheel_offset_x} ${wheel_offset_y} 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rear_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
        <slip1>0.8</slip1>
        <slip2>0.8</slip2>
    </gazebo>


    <!-- REAR RIGHT WHEEL LINK -->

    <joint name="rear_right_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_right_wheel"/>
        <origin xyz="${-2 * caster_wheel_offset_x} ${-wheel_offset_y} 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="rear_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="rear_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
        <slip1>0.8</slip1>
        <slip2>0.8</slip2>
    </gazebo>


    <!-- SOLAR MAST -->

    <joint name="solar_mast_joint" type="fixed">
        <parent link="chassis"/>
        <child link="solar_mast"/>
        <origin xyz="${chassis_length/2} 0 ${chassis_height}"/>
    </joint>

    <link name="solar_mast">
        <visual>
            <geometry><cylinder radius="0.02" length="0.17"/></geometry>
            <origin xyz="0 0 0.085"/>
            <material name="black"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.02" length="0.17"/></geometry>
            <origin xyz="0 0 0.085"/>
        </collision>
        <xacro:inertial_cylinder mass="0.5" length="0.17" radius="0.02">
            <origin xyz="0 0 0.085"/>
        </xacro:inertial_cylinder>
    </link>


    <!-- SOLAR HUB -->

    <joint name="solar_hub_joint" type="fixed">
        <parent link="solar_mast"/>
        <child link="solar_hub"/>
        <origin xyz="0 0 0.05"/>
    </joint>

    <link name="solar_hub">
        <visual>
            <geometry><cylinder radius="0.05" length="0.02"/></geometry>
            <material name="black"/>
        </visual>
    </link>


    <!-- SOLAR PANEL LEFT -->

    <joint name="solar_left_joint" type="fixed">
        <parent link="solar_hub"/>
        <child link="solar_panel_left"/>
        <origin xyz="${-solar_length/2} 0.31 -0.05" rpy="${-solar_angle} 0 0"/>
    </joint>

    <link name="solar_panel_left">
        <visual>
            <origin xyz="${solar_length/2} 0 0"/>
            <geometry>
                <box size="${solar_length} ${solar_width} ${solar_thickness}"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="${solar_length/2} 0 0"/>
            <geometry>
                <box size="${solar_length} ${solar_width} ${solar_thickness}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${solar_mass}"
            x="${solar_length}" y="${solar_width}" z="${solar_thickness}">
            <origin xyz="${solar_length/2} 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="solar_panel_left">
        <material>Gazebo/Silver</material>
    </gazebo>


    <!-- SOLAR PANEL RIGHT -->

    <joint name="solar_right_joint" type="fixed">
        <parent link="solar_hub"/>
        <child link="solar_panel_right"/>
        <origin xyz="${-solar_length/2} -0.31 -0.05" rpy="${solar_angle} 0 0"/>
    </joint>

    <link name="solar_panel_right">
        <visual>
            <origin xyz="${solar_length/2} 0 0"/>
            <geometry>
                <box size="${solar_length} ${solar_width} ${solar_thickness}"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="${solar_length/2} 0 0"/>
            <geometry>
                <box size="${solar_length} ${solar_width} ${solar_thickness}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${solar_mass}"
            x="${solar_length}" y="${solar_width}" z="${solar_thickness}">
            <origin xyz="${solar_length/2} 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="solar_panel_right">
        <material>Gazebo/Silver</material>
    </gazebo>


</robot>